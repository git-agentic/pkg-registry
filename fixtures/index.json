{
  "_comment": "Local fixture registry. `make-fixtures` packs each version's package/ dir into a .tgz and fills in integrity + sizes at build time. signature/provenance are declared here to simulate npm registry signing + build provenance and are signed with a synthetic test key at build time.",
  "packages": {
    "leftpad-lite": {
      "class": "benign",
      "expect": { "verdict": "allow" },
      "versions": {
        "1.0.0": { "signature": "valid", "provenance": false },
        "1.0.1": { "signature": "valid", "provenance": false }
      }
    },
    "net-fetch-lite": {
      "class": "benign",
      "expect": { "verdict": "allow" },
      "versions": {
        "1.0.0": { "signature": "valid", "provenance": false },
        "1.0.1": { "signature": "valid", "provenance": false },
        "1.0.2": { "signature": "valid", "provenance": false }
      }
    },
    "color-stream": {
      "class": "malicious",
      "expect": { "1.4.0": "allow", "1.4.1": "block" },
      "versions": {
        "1.4.0": { "signature": "valid", "provenance": false },
        "1.4.1": { "signature": "valid", "provenance": false }
      }
    },
    "enforce-probe": {
      "class": "benign",
      "expect": { "verdict": "allow" },
      "versions": {
        "1.0.0": { "signature": "valid", "provenance": false }
      }
    },
    "sig-tampered": {
      "class": "benign",
      "versions": {
        "1.0.0": { "signature": "tampered", "provenance": false }
      }
    },
    "sig-unsigned": {
      "class": "benign",
      "versions": {
        "1.0.0": { "signature": "none", "provenance": false }
      }
    },
    "sig-unknown": {
      "class": "benign",
      "versions": {
        "1.0.0": { "signature": "unknown-key", "provenance": false }
      }
    },
    "prov-absent": {
      "class": "benign",
      "versions": {
        "1.0.0": { "signature": "valid", "provenance": false }
      }
    },
    "prov-unknown": {
      "class": "benign",
      "versions": { "1.0.0": { "signature": "valid", "provenance": "claimed" } }
    },
    "prov-mismatch": {
      "class": "benign",
      "versions": { "1.0.0": { "signature": "valid", "provenance": { "attestationsFile": "sigstore-3.0.0.attestations.json" } } }
    },
    "violation-fs-probe": {
      "class": "benign",
      "versions": { "1.0.0": { "signature": "valid", "provenance": false } }
    },
    "violation-net-probe": {
      "class": "benign",
      "versions": { "1.0.0": { "signature": "valid", "provenance": false } }
    },
    "expres": {
      "class": "benign",
      "versions": { "1.0.0": { "signature": "valid", "provenance": false } }
    },
    "express": {
      "class": "benign",
      "versions": { "1.0.0": { "signature": "valid", "provenance": false } }
    },
    "steady-lib": {
      "class": "benign",
      "expect": { "verdict": "allow" },
      "versions": {
        "1.0.0": { "signature": "valid", "provenance": false, "time": "2025-01-01T00:00:00.000Z", "maintainers": ["alice"] },
        "2.0.0": { "signature": "valid", "provenance": false, "time": "2025-01-15T00:00:00.000Z", "maintainers": ["alice"] }
      }
    },
    "hijacked-lib": {
      "class": "malicious",
      "expect": { "1.0.0": "allow", "2.0.0": "block" },
      "versions": {
        "1.0.0": { "signature": "valid", "provenance": false, "time": "2024-01-01T00:00:00.000Z", "maintainers": ["alice"] },
        "2.0.0": { "signature": "valid", "provenance": false, "time": "2025-06-01T00:00:00.000Z", "maintainers": ["mallory"] }
      }
    },
    "freshdrop": {
      "class": "malicious",
      "expect": { "verdict": "block" },
      "versions": {
        "1.0.0": { "signature": "valid", "provenance": false, "time": "2025-03-01T00:00:00.000Z", "maintainers": ["newdev"] }
      }
    },
    "payload-loader-preinstall": { "class": "malicious", "expect": { "1.0.0": "block" }, "versions": { "1.0.0": { "signature": "valid", "provenance": false } } },
    "payload-loader-entry": { "class": "malicious", "expect": { "1.0.0": "block" }, "versions": { "1.0.0": { "signature": "valid", "provenance": false } } },
    "payload-loader-bin": { "class": "malicious", "expect": { "1.0.0": "block" }, "versions": { "1.0.0": { "signature": "valid", "provenance": false } } },
    "loader-lookalike": { "class": "benign", "expect": { "verdict": "allow" }, "versions": { "1.0.0": { "signature": "valid", "provenance": false } } }
  }
}
