{
  "name": "sentinel-registry",
  "version": "0.1.0-alpha.2",
  "private": true,
  "description": "Sentinel — an agent-auditable security/audit proxy for the npm ecosystem (Phase 1 wedge).",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "_comment": "Developed against Node 24 (Active LTS, June 2026). Node 22 is Maintenance LTS and also supported."
  },
  "workspaces": [
    "packages/core",
    "packages/proxy",
    "packages/sandbox",
    "packages/cli",
    "packages/mcp",
    "packages/action",
    "packages/steward"
  ],
  "scripts": {
    "build": "tsc --build && node packages/sandbox/scripts/build-native.mjs",
    "typecheck": "tsc --build --noEmit false",
    "test": "node --import tsx --test packages/**/test/*.test.ts",
    "fixtures": "tsx scripts/make-fixtures.ts",
    "advisories": "tsx scripts/make-advisories.ts",
    "vulns": "tsx scripts/make-vulns.ts",
    "proxy": "tsx packages/proxy/src/index.ts",
    "demo": "npm run fixtures && tsx scripts/demo.ts",
    "benchmark:publish": "tsx scripts/benchmark-publish.ts",
    "compat:clients": "tsx scripts/compat-clients.ts",
    "steward": "tsx packages/steward/src/index.ts",
    "cli": "tsx packages/cli/src/index.ts",
    "pretest": "npm run fixtures"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
